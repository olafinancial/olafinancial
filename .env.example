# ==============================================================
# OlaFinancial — Environment Variables
# ==============================================================
# Copy this file to .env and fill in your real values.
# Get these from: Supabase Dashboard → Connect → App Frameworks
# NEVER commit .env to version control.
# ==============================================================

# ── SUPABASE ───────────────────────────────────────────────────
# Your project URL (same value used in js/config.js)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Publishable key — safe to expose to the browser (anon key)
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Secret key — server-side ONLY, bypasses RLS — NEVER expose this
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# JWKS endpoint for verifying user JWTs (auto-derived from URL if blank)
SUPABASE_JWKS_URL=https://YOUR_PROJECT_ID.supabase.co/auth/v1/.well-known/jwks.json

# ── SERVER ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
